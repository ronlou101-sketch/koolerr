# Supabase
# Copy this file to .env.local and fill in your project values.
# Never commit .env.local to version control.

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only — bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Platform
# The Tenant ID this deployment serves. Used to resolve the platform
# context from an authenticated Supabase Auth session (Phase 11+).
PLATFORM_TENANT_ID=your_tenant_id
