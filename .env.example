# =============================================================================
# Koolerr Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
#
# Required for V1 launch:
#   NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY,
#   SUPABASE_SERVICE_ROLE_KEY, PLATFORM_TENANT_ID, ANTHROPIC_API_KEY,
#   NEXT_PUBLIC_APP_URL
#
# Optional (safe to omit — features degrade gracefully):
#   STRIPE_*, GITHUB_TOKEN,
#   OPENAI_API_KEY, MANUS_API_KEY, HEYGEN_*, HIGGSFIELD_API_KEY, ELEVENLABS_*
#
# See docs/adr/ADR-022-production-deployment.md for full details.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# Get these from: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only — bypasses Row-Level Security. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# -----------------------------------------------------------------------------
# Platform
# Run supabase/seed.sql once on your production Supabase project.
# Copy the returned UUID here.
# -----------------------------------------------------------------------------
PLATFORM_TENANT_ID=your_tenant_uuid_from_seed_sql

# -----------------------------------------------------------------------------
# AI Provider — Anthropic
# Required for Engagement Runs (Atlas + all Workforces).
# Get your key at https://console.anthropic.com
# Server-only. NEVER expose to the browser.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key

# -----------------------------------------------------------------------------
# AI Provider — OpenAI (optional — used by OpenAI adapter in Model Gateway)
# Get your key at https://platform.openai.com/api-keys
# Server-only. NEVER expose to the browser.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
# OPENAI_API_URL=https://api.openai.com/v1  # override only if using a proxy

# -----------------------------------------------------------------------------
# AI Provider — Manus (optional — used by Manus adapter in Model Gateway)
# Server-only. NEVER expose to the browser.
# -----------------------------------------------------------------------------
MANUS_API_KEY=your_manus_api_key
# MANUS_API_URL=  # override only if not using the default endpoint

# -----------------------------------------------------------------------------
# AI Provider — HeyGen (optional — avatar video generation)
# Get your key at https://app.heygen.com/settings?nav=API
# Obtain HEYGEN_AVATAR_ID and HEYGEN_VOICE_ID from your HeyGen account.
# Server-only. NEVER expose to the browser.
# -----------------------------------------------------------------------------
HEYGEN_API_KEY=your_heygen_api_key
HEYGEN_AVATAR_ID=your_heygen_avatar_id
HEYGEN_VOICE_ID=your_heygen_voice_id
# HEYGEN_API_URL=https://api.heygen.com  # override only if using a proxy

# -----------------------------------------------------------------------------
# AI Provider — Higgsfield (optional — stub; pending official API documentation)
# Server-only. NEVER expose to the browser.
# -----------------------------------------------------------------------------
HIGGSFIELD_API_KEY=your_higgsfield_api_key

# -----------------------------------------------------------------------------
# AI Provider — ElevenLabs (optional — voice synthesis)
# Get your key at https://elevenlabs.io/app/settings/api-keys
# Obtain ELEVENLABS_VOICE_ID from your ElevenLabs voice library.
# ELEVENLABS_MODEL_ID defaults to eleven_multilingual_v2 if omitted.
# Server-only. NEVER expose to the browser.
# -----------------------------------------------------------------------------
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# ELEVENLABS_API_URL=https://api.elevenlabs.io  # override only if using a proxy

# -----------------------------------------------------------------------------
# Application URL
# The base URL of this deployment. Used for Stripe redirect URLs.
# No trailing slash.
# Examples: https://koolerr.com | https://koolerr.vercel.app | http://localhost:3000
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://your-domain.com

# -----------------------------------------------------------------------------
# Stripe (optional — billing features degrade gracefully if omitted)
# Get these from: Stripe Dashboard → Developers → API keys
# The webhook secret is generated when you create the webhook endpoint in Stripe.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_BUILD_PRICE_ID=price_...
STRIPE_GROW_PRICE_ID=price_...
STRIPE_SCALE_PRICE_ID=price_...

# -----------------------------------------------------------------------------
# GitHub (optional — issue creation skips silently if omitted)
# Create a Personal Access Token with repo scope at:
# https://github.com/settings/tokens
# Server-only. NEVER expose to the browser.
# -----------------------------------------------------------------------------
GITHUB_TOKEN=ghp_...
